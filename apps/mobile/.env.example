# ==========================================

# BodyOS Mobile Environment Variables

# ==========================================

# Public variables only.

# Never store service keys or AI provider keys in mobile apps.

# ==========================================

# Supabase (safe to expose)

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# API Gateway

EXPO_PUBLIC_GATEWAY_URL=https://api.bodyos.app

# Development

MOCK_AI=false
