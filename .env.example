# ==========================================

# BodyOS Environment Variables Template

# ==========================================

# Copy this file to .env and fill in your values.

# Never commit real credentials to GitHub.

# ==========================================

# ==========================================

# Supabase

# ==========================================

# Backend

SUPABASE_URL=https://your-project.supabase.co

# Backend only - NEVER expose to mobile clients

SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Backend only

SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Safe to expose in mobile applications

SUPABASE_ANON_KEY=your_supabase_anon_key

# ==========================================

# AI Providers

# ==========================================

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

GROQ_API_KEY=your_groq_api_key

GEMINI_API_KEY=your_gemini_api_key

# ==========================================

# Application Configuration

# ==========================================

NODE_ENV=development

API_BASE_URL=http://localhost:3000

ALLOWED_ORIGINS=http://localhost:8081,https://bodyos.app

COOKIE_SECRET=your_random_32_character_secret

# ==========================================

# Redis

# ==========================================

REDIS_URL=redis://localhost:6379

# ==========================================

# Mobile / Expo

# ==========================================

# Safe to expose in client applications

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

EXPO_PUBLIC_GATEWAY_URL=https://bodyos-gateway.onrender.com

EXPO_PUBLIC_AI_SERVICE_URL=http://localhost:3001

# ==========================================

# Development

# ==========================================

MOCK_AI=false

LOCAL_IP=192.168.x.x

# ==========================================

# Internal Services

# ==========================================

# Used for communication between backend services

AI_API_KEY=your_internal_ai_service_key

# Public client key (if applicable)

EXPO_PUBLIC_AI_API_KEY=your_public_ai_api_key
